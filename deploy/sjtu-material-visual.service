[Unit]
Description=SJTU Material Authenticity Visual Dashboard
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/lighthouse/sjtu_material_visual
Environment=HOST=0.0.0.0
Environment=PORT=3002
ExecStart=/home/lighthouse/sjtu_material_visual/start.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
